<Window x:Class="Project_2maiss_Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Lang[AppTitle]}" Height="680" Width="520"
        Icon="logo.ico"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E" Foreground="#D4D4D4" FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#1E1E1E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#333337"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3E3E42"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding Lang[AppTitle]}" FontSize="32" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding Lang[AppVersion]}" FontSize="12" Foreground="#888888"/>
            </StackPanel>

            <ComboBox Grid.Column="1" 
                      ItemsSource="{Binding AvailableLanguages}" 
                      DisplayMemberPath="Name" 
                      SelectedValuePath="Code" 
                      SelectedValue="{Binding SelectedLanguage}"
                      Width="90" Height="26" VerticalAlignment="Top" 
                      HorizontalAlignment="Right" Margin="0,8,0,0"/>
        </Grid>

        <Border Grid.Row="1" Background="#5A1D1D" 
                BorderBrush="#FF5C5C" BorderThickness="1" CornerRadius="5" Margin="0,0,0,10" 
                Visibility="{Binding NeedsBinding, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding Lang[WarnNoBind]}" 
                       Foreground="#FFD7D7" Padding="10" TextWrapping="Wrap" FontWeight="SemiBold" LineHeight="20"/>
        </Border>

        <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0">
            <TabItem Header="{Binding Lang[TabPlay]}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,15,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding GamePath}" Grid.Column="0" Margin="0,0,8,0" IsReadOnly="True" Height="28"/>
                            <Button Grid.Column="1" Content="{Binding Lang[BtnBrowse]}" Width="75" Height="28" Click="BtnBrowse_Click"/>
                        </Grid>
                        <Border BorderThickness="0,0,0,1" BorderBrush="#3E3E42" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Lang[LimitRadius]}" Foreground="#D4D4D4"/>
                                <TextBlock Text="{Binding LimitRadiusText}" Foreground="#888888" FontSize="11"/>
                            </StackPanel>
                            <Slider Grid.Column="1" Minimum="0" Maximum="2000" Value="{Binding LimitRadius}" TickFrequency="10" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="5,0"/>
                            <TextBox Grid.Column="2" Text="{Binding LimitRadius, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" PreviewTextInput="NumberValidationTextBox" TextAlignment="Center" VerticalAlignment="Center" Height="26"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Lang[AoeRadius]}" Foreground="#D4D4D4"/>
                                <TextBlock Text="{Binding AoeRadiusText}" Foreground="#888888" FontSize="11"/>
                            </StackPanel>
                            <Slider Grid.Column="1" Minimum="0" Maximum="1000" Value="{Binding AoeRadius}" TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="5,0"/>
                            <TextBox Grid.Column="2" Text="{Binding AoeRadius, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" PreviewTextInput="NumberValidationTextBox" TextAlignment="Center" VerticalAlignment="Center" Height="26"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Lang[SingleRadius]}" Foreground="#D4D4D4"/>
                                <TextBlock Text="{Binding SingleRadiusText}" Foreground="#888888" FontSize="11"/>
                            </StackPanel>
                            <Slider Grid.Column="1" Minimum="0" Maximum="500" Value="{Binding SingleRadius}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="5,0"/>
                            <TextBox Grid.Column="2" Text="{Binding SingleRadius, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" PreviewTextInput="NumberValidationTextBox" TextAlignment="Center" VerticalAlignment="Center" Height="26"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding SensRightText}" Foreground="#D4D4D4" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="10.0" Value="{Binding SensRight}" TickFrequency="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="5,0"/>
                            <TextBox Grid.Column="2" Text="{Binding SensRight, UpdateSourceTrigger=PropertyChanged, StringFormat=N1}" PreviewTextInput="NumberValidationTextBox" TextAlignment="Center" VerticalAlignment="Center" Height="26"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding SensLeftText}" Foreground="#D4D4D4" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="10.0" Value="{Binding SensLeft}" TickFrequency="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="5,0"/>
                            <TextBox Grid.Column="2" Text="{Binding SensLeft, UpdateSourceTrigger=PropertyChanged, StringFormat=N1}" PreviewTextInput="NumberValidationTextBox" TextAlignment="Center" VerticalAlignment="Center" Height="26"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="5" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Lang[RightKey]}" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,0,0,10"/>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="45"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Lang[ClickKey]}" Foreground="#888888" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding MouseActions}" SelectedItem="{Binding ActionSingleRight}" Height="24"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="45"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Lang[AoeKey]}" Foreground="#888888" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding MouseActions}" SelectedItem="{Binding ActionAoeRight}" Height="24"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="5" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Lang[LeftKey]}" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,0,0,10"/>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="45"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Lang[ClickKey]}" Foreground="#888888" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding MouseActions}" SelectedItem="{Binding ActionSingleLeft}" Height="24"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="45"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Lang[AoeKey]}" Foreground="#888888" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding MouseActions}" SelectedItem="{Binding ActionAoeLeft}" Height="24"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                        
                        <CheckBox Content="{Binding Lang[EnhancePointer]}" IsChecked="{Binding EnhancePointer}" Foreground="#D4D4D4" Margin="0,0,0,5"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{Binding Lang[TabHardware]}">
                <StackPanel Margin="0,20,0,0">
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Lang[Port]}" VerticalAlignment="Center" Foreground="#D4D4D4"/>
                        <TextBox Grid.Column="1" Text="{Binding Port}" Height="26"/>
                        
                        <TextBlock Grid.Column="3" Text="{Binding Lang[BaudRate]}" VerticalAlignment="Center" Foreground="#D4D4D4"/>
                        <TextBox Grid.Column="4" Text="{Binding BaudRate}" PreviewTextInput="NumberValidationTextBox" Height="26"/>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Lang[TxInterval]}" VerticalAlignment="Center" Foreground="#D4D4D4" TextWrapping="Wrap"/>
                        <TextBox Grid.Column="1" Text="{Binding TxIntervalMs}" PreviewTextInput="NumberValidationTextBox" Height="26"/>
                        
                        <TextBlock Grid.Column="3" Text="{Binding Lang[InterceptKey]}" VerticalAlignment="Center" Foreground="#D4D4D4" TextWrapping="Wrap"/>
                        <ComboBox Grid.Column="4" ItemsSource="{Binding AvailableKeys}" DisplayMemberPath="Name" SelectedValuePath="Code" SelectedValue="{Binding InterceptKey}" Height="26"/>
                    </Grid>

                    <TextBlock Text="{Binding Lang[WarnHardwareRestart]}" Foreground="#FFC66D" TextWrapping="Wrap" Margin="0,0,0,25" FontSize="11" FontStyle="Italic"/>

                    <Button Content="{Binding Lang[BtnBind]}" Height="35" Background="#007ACC" Click="BtnBind_Click"/>
                    <TextBlock Text="{Binding BindStatus}" Foreground="#FFC66D" Margin="0,15,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="{Binding Lang[BtnSave]}" Height="40" Margin="0,0,8,0" Click="BtnSave_Click"/>
            <Button Grid.Column="1" Content="{Binding Lang[BtnStart]}" Height="40" Margin="8,0,0,0" Background="#007ACC" Click="BtnStart_Click"/>
        </Grid>
    </Grid>
</Window>